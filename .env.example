# 复制为 .env 或在 shell 中 export（不要将含真实密码的 .env 提交到仓库）

ROUTER_HOST=192.168.11.254
ROUTER_PORT=22100
ROUTER_USER=your_router_user
ROUTER_PASSWORD=your_router_password

# 可选：覆盖 NAT 源地址（对应 config 中 nat.target_src）
# DOMAIN_TEST_NAT_TARGET_SRC=192.168.11.115

# 可选：Chrome 非默认安装路径时，指向可执行文件（与 GOOGLE_CHROME_BIN 二选一即可）
# CHROME_PATH=/usr/bin/google-chrome-stable
# GOOGLE_CHROME_BIN=/usr/bin/google-chrome-stable
